# Copy this file to .env and adjust as needed.
# Matches the credentials in the repo-root docker-compose.yml by default.

DATABASE_URL="postgresql://wie:wie_local_dev@localhost:5432/wie_recruitment?schema=public"

# Local Express server port
PORT=4000

# Origin allowed to make credentialed (cookie) requests to this API
FRONTEND_ORIGIN=http://localhost:3000

# Google OAuth Client ID (from Google Cloud Console — Credentials → OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=

# Only emails ending in this domain may sign in
COLLEGE_EMAIL_DOMAIN=vitstudent.ac.in

# Signs the session cookie's JWT — generate your own, e.g. `openssl rand -hex 32`
SESSION_SECRET=

# Hardcoded 2026 admin/super_admin allowlist, format: email:role,email:role
# e.g. ADMIN_ALLOWLIST=chair@vitstudent.ac.in:super_admin,techlead@vitstudent.ac.in:admin
ADMIN_ALLOWLIST=
